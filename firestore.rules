rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isAdmin() {
      return isSignedIn() && request.auth.token.admin == true;
    }

    function isApproved() {
      return isSignedIn()
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.aprobado == true;
    }

    // Guayaquil es UTC-5 todo el año (sin horario de verano), así que sumar
    // 5 horas a la hora local guardada da el instante UTC equivalente,
    // comparable directamente contra `request.time`.
    function inicioSesionUTC(session) {
      let f = session.fecha.split('-');
      let h = session.hora.split(':');
      return timestamp.date(int(f[0]), int(f[1]), int(f[2]))
        + duration.value(int(h[0]) * 60 + int(h[1]) + 5 * 60, 'm');
    }

    function haComenzado(session) {
      return request.time >= inicioSesionUTC(session);
    }

    // Lista de acceso que gestiona la admin. Un alumno solo puede leer su
    // propia entrada (para saber si ya fue aprobado); la admin gestiona todo.
    match /approvedEmails/{email} {
      allow get: if isAdmin() || (isSignedIn() && request.auth.token.email == email);
      allow list: if isAdmin();
      allow write: if isAdmin();
    }

    // Solicitudes de acceso: cuando alguien entra con Google y no está
    // aprobado, deja registrada su solicitud para que la admin la vea y
    // decida. El propio usuario (aún sin aprobar) crea la suya.
    match /accessRequests/{uid} {
      allow get: if isAdmin() || isOwner(uid);
      allow list: if isAdmin();
      allow create: if isOwner(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.estado == 'pendiente';
      allow update, delete: if isAdmin();
    }

    match /users/{uid} {
      allow read: if isOwner(uid) || isAdmin();

      // El propio alumno crea su doc al primer login aprobado, siempre
      // como "alumno" y ya aprobado — nunca puede auto-asignarse admin.
      allow create: if isOwner(uid)
        && request.resource.data.email == request.auth.token.email
        && request.resource.data.rol == 'alumno'
        && request.resource.data.aprobado == true
        && exists(/databases/$(database)/documents/approvedEmails/$(request.auth.token.email));

      // El dueño edita su perfil pero nunca sus propios rol/aprobado.
      allow update: if isAdmin()
        || (isOwner(uid)
            && !request.resource.data.diff(resource.data).affectedKeys().hasAny(['rol', 'aprobado', 'uid', 'email']));

      allow delete: if isAdmin();

      match /weightLogs/{logId} {
        allow read: if isOwner(uid) || isAdmin();
        allow create, update: if isOwner(uid) || isAdmin();
        allow delete: if isAdmin();
      }
    }

    // Fase 2 — horarios y reservas.
    match /classTemplates/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /classSessions/{id} {
      allow read: if isApproved();
      allow create, delete: if isAdmin();

      // La admin edita lo que sea; un alumno aprobado solo puede mover
      // `cuposOcupados` en 1 (reservar o cancelar su propio cupo) — nunca
      // tocar capacidad, estado ni cualquier otro campo, y nunca sobre una
      // sesión que ya comenzó (reserva y cancelación quedan bloqueadas).
      allow update: if isAdmin()
        || (isApproved()
            && !haComenzado(resource.data)
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['cuposOcupados'])
            && (request.resource.data.cuposOcupados == resource.data.cuposOcupados + 1
                || request.resource.data.cuposOcupados == resource.data.cuposOcupados - 1));
    }

    match /bookings/{id} {
      // Cualquier alumno aprobado puede ver las reservas: la app muestra
      // quiénes van a cada clase (el nombre viaja denormalizado en la
      // propia reserva, así que users/ sigue siendo privado).
      allow read: if isAdmin() || isApproved();

      // El id compuesto "sessionId_uid" hace imposible duplicar la reserva;
      // solo se puede crear como "reservado" y a nombre de uno mismo.
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid
        && id == request.resource.data.sessionId + '_' + request.auth.uid
        && request.resource.data.estado == 'reservado';

      // El alumno solo puede cancelar su propia reserva (nunca tocar
      // `asistio`, que es exclusivo de la admin).
      allow update: if isAdmin()
        || (isApproved()
            && resource.data.uid == request.auth.uid
            && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado'])
            && request.resource.data.estado == 'cancelado');

      allow delete: if isAdmin();
    }

    // Fase 3 — nutrición.
    match /nutritionForms/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow create: if isApproved() && request.resource.data.uid == request.auth.uid;

      // El alumno solo edita su propio formulario mientras la admin no lo
      // haya empezado a revisar; una vez en revisión, solo la admin escribe.
      allow update: if isAdmin()
        || (isApproved()
            && resource.data.uid == request.auth.uid
            && resource.data.estado == 'pendiente'
            && request.resource.data.uid == resource.data.uid);

      allow delete: if isAdmin();
    }

    match /nutritionPlans/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // Fase 4 — medallas.
    match /skills/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /achievements/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);

      // La admin puede otorgar medallas directamente (ya validadas), por
      // ejemplo las de Constancia que ya no calcula una Cloud Function.
      allow create: if isAdmin()
        || (isApproved()
            && request.resource.data.uid == request.auth.uid
            && request.resource.data.estado == 'pendiente');

      // Mientras sigue pendiente, el dueño puede corregir nivel/fecha/video;
      // en cualquier estado puede marcar que ya vio la celebración. Todo lo
      // demás (validar, rechazar, pin entregado) es exclusivo de la admin.
      allow update: if isAdmin()
        || (isApproved()
            && resource.data.uid == request.auth.uid
            && (
              (resource.data.estado == 'pendiente'
                && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['nivel', 'fechaLogro', 'videoPath']))
              || (request.resource.data.diff(resource.data).affectedKeys().hasOnly(['celebrado'])
                  && request.resource.data.celebrado == true)
            ));

      allow delete: if isAdmin();
    }

    // Fase 5 — membresías. Sin pagos in-app: la admin gestiona todo a mano.
    match /membershipPlans/{id} {
      allow read: if isApproved();
      allow write: if isAdmin();
    }

    match /memberships/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    match /payments/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow write: if isAdmin();
    }

    // El alumno reporta su propio comprobante (creación real vía route
    // handler con Admin SDK); solo la coach transiciona el estado.
    match /paymentReports/{id} {
      allow read: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow create: if isApproved()
        && request.resource.data.uid == request.auth.uid
        && request.resource.data.estado == 'pendiente';
      allow update: if isAdmin()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['estado', 'revisadoPor', 'revisadoAt'])
        && request.resource.data.estado == 'revisado';
      allow delete: if isAdmin();
    }

    // Todavía no hay más colecciones activas: se agregan rules por fase,
    // junto con cada feature (ver roadmap-la-terraza.md).
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
